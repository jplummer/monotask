# Devices for App Store screenshots
devices([
  "iPhone 14 Plus",      # 1284×2778 — required by App Store Connect
])

languages(["en-US"])

scheme("Monotasker")

output_directory("./fastlane/screenshots")

clear_previous_screenshots(true)

# Suppress system dialogs (EventKit permission won't appear in screenshot mode)
erase_simulator(false)
